{
  "expo": {
    "name": "My Twin",
    "slug": "my-twin",
    "owner": "soulsync.ai",
    "version": "1.0.0",
    "runtimeVersion": {
      "policy": "sdkVersion"
    },
    "orientation": "portrait",
    "scheme": "mytwin",
    "userInterfaceStyle": "dark",
    "icon": "./assets/brand/icon.png",
    "splash": {
      "image": "./assets/splash/splash.png",
      "resizeMode": "contain",
      "backgroundColor": "#0A0014"
    },
    "assetBundlePatterns": [
      "**/*"
    ],
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.soulsync.mytwin",
      "buildNumber": "1",
      "infoPlist": {
        "NSMicrophoneUsageDescription": "My Twin needs microphone to hear your voice, feel your emotions, and whisper back to you.",
        "NSSpeechRecognitionUsageDescription": "\u064a\u0633\u062a\u062e\u062f\u0645 \u0627\u0644\u062a\u0648\u0623\u0645 \u0627\u0644\u062a\u0639\u0631\u0641 \u0639\u0644\u0649 \u0627\u0644\u0635\u0648\u062a \u0644\u062a\u062d\u0648\u064a\u0644 \u0643\u0644\u0627\u0645\u0643 \u0625\u0644\u0649 \u0646\u0635.",
        "NSCameraUsageDescription": "My Twin needs camera to see you, follow your face, and respond to your presence with life-like movements.",
        "NSMotionUsageDescription": "My Twin needs motion sensors to feel your steps, your movements, and sync its heartbeat with yours."
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/brand/adaptive-icon.png",
        "backgroundColor": "#0A0014"
      },
      "package": "com.soulsync.mytwin",
      "versionCode": 1,
      "permissions": [
        "android.permission.INTERNET",
        "android.permission.ACCESS_NETWORK_STATE",
        "android.permission.RECORD_AUDIO",
        "android.permission.VIBRATE",
        "android.permission.MODIFY_AUDIO_SETTINGS",
        "android.permission.POST_NOTIFICATIONS",
        "com.android.vending.BILLING",
        "CAMERA",
        "RECORD_AUDIO",
        "BODY_SENSORS",
        "ACTIVITY_RECOGNITION"
      ]
    },
    "plugins": [
      "expo-router",
      "expo-localization",
      [
        "expo-build-properties",
        {
          "android": {
            "newArchEnabled": false,
            "compileSdkVersion": 35,
            "targetSdkVersion": 35,
            "minSdkVersion": 24,
            "enableProguardInReleaseBuilds": true
          },
          "ios": {
            "newArchEnabled": false,
            "deploymentTarget": "15.1"
          }
        }
      ],
      [
        "react-native-google-mobile-ads",
        {
          "androidAppId": "ca-app-pub-3940256099942544~3347511713",
          "iosAppId": "ca-app-pub-3940256099942544~1458002511",
          "delayAppMeasurement": true
        }
      ],
      "./plugins/withGooglePlayBilling",
      "expo-camera",
      "expo-sensors"
    ],
    "extra": {
      "router": {
        "origin": false
      },
      "eas": {
        "projectId": "7b96fc72-c7e0-4ebf-937f-e41354fc0ebe"
      },
      "API_URL": "my-twin-pro-production.up.railway.app",
      "ENVIRONMENT": "production"
    },
    "updates": {
      "url": "https://u.expo.dev/6cb78668-322b-476f-ab25-4136d85f8d68"
    },
    "sdkVersion": "52.0.0"
  }
}